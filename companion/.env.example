# Crowly companion — operator config. Copy to `.env` and edit.
#
# Secrets live here, plaintext, gitignored. docs/architecture.md § Security
# explicitly notes: "Companion secrets (the pairing token, any HTTPS cert
# material) live in /opt/data/.env on the user's VPS — plaintext-but-
# gitignored, never in any vault or this repo."

# The hostname Caddy provisions a Let's Encrypt cert for. The DNS A record
# for this hostname must already point at this VPS before `docker compose up`,
# or the ACME HTTP-01 challenge fails.
CROWLY_DOMAIN=crowly.example.com

# The shared secret the iOS app presents on every request, and the emitter
# presents on every POST /ingest. Generate with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Then put the same token in the app via QR pairing (the pairing payload
# at https://{CROWLY_DOMAIN}/pair embeds it).
CROWLY_PAIRING_TOKEN=replace-me-with-a-long-random-token

# Public URL the app dials. Default is `https://${CROWLY_DOMAIN}`; override
# only if you front the companion at a non-root path (rare).
# CROWLY_PUBLIC_URL=https://crowly.example.com

# ---------------------------------------------------------------------------
# Push relay (optional — leave all three unset to disable push)
# ---------------------------------------------------------------------------
# The companion sends a content-free pointer to the relay when a digest's
# urgency is `high` or `urgent` (docs/architecture.md § Push). Normal/low
# urgency digests do not push — they wait to be pulled. Push is best-effort:
# a relay outage never fails an ingest, just skips the push.
#
# All three vars must be set to enable push. Missing any one → silent no-op
# at boot ("push disabled (missing: ...)" log line), and the companion runs
# fine as a pull-only inbox. This is the M1 single-user dev configuration.
#
# CROWLY_RELAY_URL=https://relay.crowly.example
# CROWLY_RELAY_TOKEN=the-shared-bearer-the-relay-operator-gives-you
#
# Routing token: what the iOS app showed you after it registered with the
# relay during pairing. For M1 (no in-app pairing flow yet), the operator
# pastes this in by hand after running through onboarding Step 3. Once the
# pairing flow lands, the companion will store this server-side and this
# env var becomes the bootstrap value rather than the live source.
# CROWLY_ROUTING_TOKEN=rt_xxxxxxxxxxxxxxxxxxxxxxxxxx
