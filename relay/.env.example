# Crowly push relay — operator config. Copy to `.env` and edit.
#
# The relay is project-operated (NOT self-hosted by users) because the
# Apple `.p8` push auth key is bound to the iOS app's Apple Team + bundle
# id and can't be distributed.

# Bearer companions present on POST /push. Generate with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Then put the SAME value in every paired companion's env as
# CROWLY_RELAY_TOKEN. Rotate by re-running the generator + redeploying.
RELAY_PUSH_TOKEN=replace-me-with-a-long-random-token

# Per-routing_token rate limit on /push. 30/min is generous; tune up if a
# legitimate workload needs it. The cap is a per-process in-memory window
# (no Redis); fine for the single-box M1 relay.
RELAY_RATE_LIMIT_PER_MINUTE=30

# ---------------------------------------------------------------------------
# APNs configuration
# ---------------------------------------------------------------------------
# APNS_ENV picks the mode:
#   mock        — MockAPNsClient (default). Records pushes in memory; never
#                 calls Apple. Use this for local testing and the first boot.
#   sandbox     — Talks to api.sandbox.push.apple.com. Use with TestFlight
#                 builds or development-provisioned devices.
#   production  — Talks to api.push.apple.com. Production.
APNS_ENV=mock

# The iOS app's bundle identifier. Required for real APNs; required for mock
# only as a label that flows through to the recorded push (lets tests assert
# the topic round-trip). In mock mode, any string works.
APNS_TOPIC=com.example.crowly

# The Apple-supplied 10-char Key ID for the .p8 (shown in App Store Connect
# next to the key when you download it). Required when APNS_ENV != mock.
APNS_KEY_ID=

# Your Apple Team ID (10-char alphanumeric, same value in every Apple-issued
# Team membership). Required when APNS_ENV != mock.
APNS_TEAM_ID=

# Path to the .p8 file INSIDE the container. The compose file mounts
# ${APNS_KEY_HOST_DIR} (default ./apns-keys) at /etc/apns:ro, so a typical
# value is /etc/apns/AuthKey_XXXXXXXXXX.p8.
APNS_KEY_PATH=/etc/apns/AuthKey_REPLACEME.p8

# Where on the host the .p8 lives. The compose file bind-mounts this dir
# read-only into the container at /etc/apns. Override if your key lives
# somewhere other than ./apns-keys.
APNS_KEY_HOST_DIR=./apns-keys
